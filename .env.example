# Kontor runs as one fixed tenant in this portfolio build. The tenant_id remains
# in every business table so the architecture can evolve without a data rewrite,
# but there is intentionally no tenant onboarding or tenant-management UI.
APP_ENV=development
HTTP_ADDR=:8080
# Host-local processes reach the Compose PostgreSQL port on 5433. Compose
# overrides this value inside containers and uses postgres:5432 directly.
DATABASE_URL=postgres://kontor:kontor@localhost:5433/kontor?sslmode=disable
DEMO_MODE=true

# Architectural constant for this single-tenant build; startup rejects a
# different value instead of silently creating a second tenant.
FIXED_TENANT_ID=00000000-0000-4000-8000-000000000001
FIXED_TENANT_SLUG=salon-nord
FIXED_TENANT_NAME=Salon Nord
FIXED_TENANT_TIMEZONE=Europe/Berlin
FIXED_TENANT_CURRENCY=EUR

# fake works without keys. Set openrouter plus both values below to exercise the
# real Stage 1 Chat Completions adapter, including tool calls and bounded retries.
LLM_PROVIDER=fake
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=Kontor

AGENT_MAX_ITERATIONS=8
AGENT_TURN_TIMEOUT=25s
AGENT_TOOL_TIMEOUT=5s
AGENT_TOOL_MAX_ATTEMPTS=3
# Persisted per conversation. Every provider request reserves against this cap
# before it starts, so concurrent work cannot overspend it.
AGENT_CONVERSATION_TOKEN_BUDGET=50000
AGENT_MAX_OUTPUT_TOKENS=800

# Each created demo conversation receives a one-time opaque capability token.
# It is sent as a Bearer token to message/trace endpoints; only its digest is
# stored. There is intentionally no shared capability value to configure here.

# Code-level scheduling guards currently enforce a 15-minute minimum lead,
# 365-day booking horizon, and 31-day maximum slot-search range.

# Replace outside demo mode. At least 32 bytes.
SLOT_TOKEN_SECRET=demo-only-change-me-32-bytes-minimum
# Must be at least AGENT_TURN_TIMEOUT plus 5s so in-flight turns can drain.
SHUTDOWN_TIMEOUT=35s
