        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|checked|defaultChecked|disabled|onChange|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, description, checked, defaultChecked, disabled, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, icon, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|t|title|state|duration|tokens|detail|mono|payload|payloadTitle|retries|key|ref|className|style|children)$/]",
        "message": "<TimelineStep> doesn't accept that prop. Declared props: id, t, title, state, duration, tokens, detail, mono, payload, payloadTitle, retries."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineStep'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:pending|running|success|retried|failed)$/]",
        "message": "<TimelineStep> state must be one of 'pending' | 'running' | 'success' | 'retried' | 'failed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToastItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|tone|title|description|duration|key|ref|className|style|children)$/]",
        "message": "<ToastItem> doesn't accept that prop. Declared props: id, tone, title, description, duration."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToastItem'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|error|info)$/]",
        "message": "<ToastItem> tone must be one of 'success' | 'warning' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|side|children|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: label, side, children."
